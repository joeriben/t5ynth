#!/bin/bash
# Post-install script for T5ynth .pkg installer
# Runs after all component packages are installed.

TARGET_VOLUME="${2:-/}"

target_path() {
    local path="$1"
    if [[ "$TARGET_VOLUME" == "/" ]]; then
        printf '%s\n' "$path"
    else
        printf '%s%s\n' "$TARGET_VOLUME" "$path"
    fi
}

APP_SUPPORT="$(target_path "/Library/Application Support/T5ynth")"
APP_BUNDLE="$(target_path "/Applications/T5ynth.app")"

# Create models directory (writable by all staff members for in-app downloads)
mkdir -p "$APP_SUPPORT/models"
chgrp staff "$APP_SUPPORT/models"
chmod 775 "$APP_SUPPORT/models"

# Ensure presets directory exists with correct permissions
mkdir -p "$APP_SUPPORT/presets"
chgrp staff "$APP_SUPPORT/presets"
chmod 755 "$APP_SUPPORT/presets"

# Remove quarantine from installed items
xattr -cr "$APP_BUNDLE" 2>/dev/null || true

exit 0
