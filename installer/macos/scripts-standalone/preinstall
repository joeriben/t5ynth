#!/bin/bash
# Remove previous T5ynth.app before installing new version.
# Prevents stale files from manual installs corrupting the bundle signature.

TARGET_VOLUME="${2:-/}"

target_path() {
    local path="$1"
    if [[ "$TARGET_VOLUME" == "/" ]]; then
        printf '%s\n' "$path"
    else
        printf '%s%s\n' "$TARGET_VOLUME" "$path"
    fi
}

rm -rf "$(target_path "/Applications/T5ynth.app")"
exit 0
